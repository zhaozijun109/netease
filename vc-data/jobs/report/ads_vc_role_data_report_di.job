 \
select distinct \
'all' AS period, \
a.character_id, \
a.character_name, \
d.expose_uv, \
b.chat_uv, \
b.total_chats, \
b.energy_consume, \
c.total_chats_10up, \
c.total_chats_30up, \
a.consum_uv, \
COALESCE(a.total_amount,0) as total_amount, \
a.type, \
