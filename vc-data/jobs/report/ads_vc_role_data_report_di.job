AND (params['itemid'] LIKE 'character_online%' OR params['itemid'] REGEXP '^[0-9]+$') \
AND event_id IN ('h1-1', 'native_chat_room_expose')  \
group by CASE  \
WHEN params['itemid'] LIKE 'character_online_%' THEN substring_index(params['itemid'], 'character_online_', -1) \
