(select type, \
status, \
audience_type, \
character_id, \
character_name, \
count(distinct user_id) as consum_uv, \
sum(order_price) as total_amount \
from vc.dwd_vc_ucr_order_amount_i_d \
where dt <= '${azkaban.flow.1.days.ago}' \
group by type, \
status, \
audience_type, \
character_id, \
character_name \
) a \
left join \
(select character_id, \
character_name, \
count(distinct user_id) as chat_uv, \
sum(talk_cnt) as total_chats, \
sum(COALESCE(energy_consume,0)) as energy_consume \
from vc.dws_vc_uc_talk_day_cnt_single_i_d \
where dt <= '${azkaban.flow.1.days.ago}' \
group by character_id, \
character_name \
) b on a.character_id=b.character_id   \
 \
