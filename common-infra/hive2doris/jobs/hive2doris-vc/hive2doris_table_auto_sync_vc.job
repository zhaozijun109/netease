execution-jar=${classpath}
class=com.netease.yuanqi.doris.Hive2DorisAutoSync
conf.spark.sql.shuffle.partitions=5
conf.spark.task.maxFailures=1
conf.spark.blacklist.enabled=false
conf.spark.sql.hive.convertMetastoreParquet=false
retries=1
params=--partition-col dt --hive-db vc_dm --doris-db vc --parallelism 2 --includes _report_,_easy_fetch_ --excludes