<assembly>
    <id>dist</id>
    <formats>
        <format>dir</format>
    </formats>
    <includeBaseDirectory>false</includeBaseDirectory>

    <fileSets>
        <fileSet>
            <directory>
                ${project.parent.basedir}/bin/
            </directory>
            <outputDirectory>bin</outputDirectory>
            <includes>
                <include>**/*</include>
            </includes>
        </fileSet>
        <fileSet>
            <directory>
                ${project.parent.basedir}/conf/
            </directory>
            <outputDirectory>conf</outputDirectory>
            <includes>
                <include>**/*</include>
            </includes>
        </fileSet>
        <fileSet>
            <directory>
                ${project.parent.basedir}/lib/
            </directory>
            <outputDirectory>jars</outputDirectory>
            <includes>
                <include>**/*</include>
            </includes>
        </fileSet>
        <fileSet>
            <directory>
                ${project.parent.basedir}/assembly/target/${easyml.jar.dir}
            </directory>
            <outputDirectory></outputDirectory>
            <includes>
                <include>${easyml.jar.basename}</include>
            </includes>
        </fileSet>
    </fileSets>

    <dependencySets>
        <dependencySet>
            <outputDirectory>jars</outputDirectory>
            <includes>
                <include>com.netease.easyml:*:jar</include>
            </includes>
            <excludes>
                <exclude>com.netease.easyml:easyml-assembly:jar</exclude>
            </excludes>
        </dependencySet>
        <dependencySet>
            <outputDirectory>jars</outputDirectory>
            <useTransitiveDependencies>true</useTransitiveDependencies>
            <unpack>false</unpack>
            <scope>runtime</scope>
            <useProjectArtifact>false</useProjectArtifact>
            <excludes>
                <exclude>com.netease.easyml:*:jar</exclude>
                <exclude>org.scala-lang:scala-compiler:jar</exclude>
            </excludes>
        </dependencySet>
    </dependencySets>

</assembly>
