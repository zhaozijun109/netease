{
  "reader": {
    "type": "basic",
    "format": "csv",
    "options": {
      "header": "false"
    },
    "schema": "label DOUBLE, features STRING"
  },
  "result_reader": {
    "type": "basic",
    "format": "json"
  },
  "component": {
    "type": "Pipeline",
    "stages": [
      {
        "type": "FFMClassifier",
        "maxIter": 3,
        "vectorSize": 2,
        "stepSize": 0.01,
        "oneWayReg": 0.00002,
        "standardization": false,
        "random": false,
        "fitIntercept": false,
        "fitLinear": false,
        "solver": "adagrad"
      },
      {
        "type": "SQLTransformer",
        "statement": "select *, prediction * 2 - 1 as t_prediction from __THIS__"
      }
    ]
  },
  "metric": [
    {
      "type": "acc",
      "predictionCol": "t_prediction"
    }
  ],
  "train": "toy_dataset/ffm/a9a_ffm.train",
  "validation": "toy_dataset/ffm/a9a_ffm.valid",

  "test": "toy_dataset/ffm/a9a_ffm.valid",
  "writer": {
    "type": "basic",
    "format": "json",
    "mode": "overwrite"
  }
}