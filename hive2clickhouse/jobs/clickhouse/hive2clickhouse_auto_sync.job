execution-jar=${classpath}
class=com.netease.wm.clickhouse.Hive2ClickhouseAutoSync
conf.spark.sql.shuffle.partitions=5
conf.spark.task.maxFailures=1
conf.spark.blacklist.enabled=false
conf.spark.sql.hive.convertMetastoreParquet=false
retries=0
params=--includes ads_user_interests_trends_di,ads_add_fans_source_scene_di,ads_creator_user_relation_score_di,ads_post_pv_fans_di,ads_premium_post_pv_scenes_di,ads_rec_item_pool_usage_di,ads_lofter_om_issue_info_dd,dwb_post_nega_feed_stat_di,ads_post_paid_user_consume_v2_di,ads_iap_pay_funnel_di,ads_limit_post_scene_rec_traffic_dd,ads_activity_mplus_api_data_di,ads_rec_all_rec_reason_di --excludes ads_ad_waterfull_user_group_di,ads_ab_revenue_business_di,ads_push_easy_fetch_paid_post_dd,ads_ecology_easy_fetch_post_wide_table_dd
