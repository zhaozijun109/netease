# ===========================================================
# AI Foundation Service - Environment Configuration
# ===========================================================
# 本文件是配置模板，不含真实密钥，可提交到 Git。
#
# 各环境配置文件（已提交到 Git，含非敏感配置）：
#   .env.test   测试环境
#   .env.pre    预发环境
#   .env.prod   线上环境
#
# 注意：密钥占位符（DATABASE_URL、NEXTAUTH_SECRET 等）
#       在 CI/CD 变量中维护，部署时由流水线替换为真实值。
#
# Next.js 加载顺序：.env.local > .env.{NODE_ENV} > .env
# ===========================================================

# --- Database ---
# MySQL 连接串，格式：mysql://user:password@host:port/database
DATABASE_URL="mysql://user:password@host:3306/ai_service"

# --- AIGW (AI Gateway) ---
# AIGW 网关地址
AIGW_BASE_URL="https://aigw.netease.com"
# 上游请求超时时间（毫秒），默认 120 秒，LLM 长响应建议适当放大
AIGW_TIMEOUT_MS=120000

# --- Auth (NextAuth) ---
# 用于签发 JWT Session 的随机密钥，建议 openssl rand -base64 32 生成
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# --- 网易 OpenID 认证 ---
# OpenID Server: https://login.netease.com/openid/
# 允许登录的邮件后缀白名单，逗号分隔；留空则允许所有通过 OpenID 认证的用户
# 示例：OPENID_ALLOWED_EMAIL_SUFFIX=@corp.netease.com,@163.com
OPENID_ALLOWED_EMAIL_SUFFIX="@corp.netease.com"

# 微前端主应用 OpenID Header 认证（可选）
# 接入微前端后，主应用通过 LOFTER-ADMIN-OPEN-ID / LOFTER-ADMIN-OPEN-ID-SIGN Header 注入用户信息。
# 设置此公钥后优先走 Header 认证流程（RSA-SHA256 签名校验），否则降级为标准 OpenID 重定向。
# CI/CD 环境可将 PEM 换行符替换为字面量 \n 后存入单行变量。
# 示例（单行）：OPENID_MF_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIB...IDAQAB\n-----END PUBLIC KEY-----"
OPENID_MF_PUBLIC_KEY=""
# 微前端签名有效期（毫秒），超时请求将被拒绝；默认 300000（5 分钟）
OPENID_MF_SIGN_TIMEOUT_MS=300000

# --- 权限管理 ---
# 初始管理员邮箱白名单，逗号分隔。
# 首次登录时 email 在此列表中的用户将自动获得 admin 角色；
# 后续可在管理后台 /users 页面手动授权/撤销，不再依赖此变量。
# 示例：ADMIN_EMAILS=alice@corp.netease.com,bob@corp.netease.com
ADMIN_EMAILS=""

# --- CORS ---
# 允许的跨域来源，逗号分隔。设为 * 允许所有来源（内网服务可保持 *）
CORS_ALLOWED_ORIGINS="*"

# --- Server ---
PORT=3000
# 影响 Prisma 日志输出、pino-pretty 等开发体验配置
NODE_ENV=development

# --- Logging ---
# 可选值: debug, info, warn, error
LOG_LEVEL=info

# NOS（大结果集 Excel 导出）
NOS_ACCESS_KEY=
NOS_ACCESS_SECRET=
NOS_ENDPOINT=
NOS_BUCKET=lofter
NOS_HOST=
NOS_OBJECT_ORIGIN=
