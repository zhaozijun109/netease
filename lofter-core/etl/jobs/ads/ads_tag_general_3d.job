type=sparksql
deploy-mode=cluster
hive.query.01=insert overwrite table lofter_dm.ads_tag_general_3d partition(dt='${azkaban.flow.1.days.ago}') select /*+ MAPJOIN(dim_date_rolling)*/ s.tag, s.domainId, s.domainName, s.isActivityTag, sum(s.hot) hot, sum(browsingUserCount) browsingUserCount, sum(browsingCount) browsingCount, sum(subscribeCount) subscribeCount, sum(postCount) postCount, sum(s.commendcount) commendcount, sum(s.praisecount) praisecount, sum(s.recommendcount) recommendcount, sum(s.reproducecount) reproducecount, sum(s.unsubscribeCount) unsubscribeCount,sum(s.newuserhot) as newuserhot, sum(s.newposthot) as newposthot, sum(s.newbrowsingcount) as newbrowsingcount, sum(s.newbrowsingusercount) as newbrowsingusercount, sum(s.newsubscribecount) as newsubscribecount, sum(s.newcommendcount) as newcommendcount, avg(hot) avgHot, avg(browsingCount) avgBrowsingCount from lofter_dm.ads_tag_general_di s join lofter.dim_date_rolling d on s.dt = d.rollingDate where d.id = '${azkaban.flow.1.days.ago}' and d.period = 3 and s.dt >= '${azkaban.flow.3.days.ago}' group by s.tag, s.domainId, s.domainName, s.isActivityTag distribute by 1;
dependencies=ads_tag_general_di