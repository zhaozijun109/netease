type=sparksql
hive.query.01=insert overwrite table lofter_dm.ads_cc_question_top_di partition(dt='${azkaban.flow.1.days.ago}') \
         select row_number() over (order by clickPv desc, clickUv desc, name desc) as id, \
                name, url, clickPv, clickUv \
         from ( \
           select \
              name, \
              search_result_url url, \
              count(1) clickPv, \
              count(distinct deviceUdid) clickUv \
           from lofter.dwd_cc_module_query_di \
           where dt >= '${azkaban.flow.30.days.ago}' and \
                 dt <= '${azkaban.flow.1.days.ago}' and \
                 eventId = 'ka1-11' and cast(regexp_extract(search_result_url, '#/([^/]+)/(\\\\d+)$', 2) as bigint) not in ( \
                    1001017,1001019,1001020,1001021,1001022,1001023,1001024,1001025,1001026,1001027,1001028,1001029,1001030, \
                    1001031,1001032,1001033,1001034,1001035,1001036,1001037,1001038,1001039,1001040,1001041,1001042,1001043, \
                    1001044,1001045,1001046,1001047,1001048,1001049,1001050,1001051,1001052,1001053,1001054,1001055,1001056, \
                    1001057,1001058,1001059,1001060,1001061,1001062,1001063,1001064,1001065,1001066,1001067,1001068,1001069, \
                    1001070,1001071,1001072,1001073,1001074,1001075,1001076,1001077,1001078,1001079,1001080,1001081,1001082, \
                    1001083,1001084,1001085,1001086,1001087,1001088,1001089,1001090,1001091,1001092,1001093,1001094,1001095, \
                    1001096,1001097,1001098,1001099,1001100,1001101,1001102,1001103,1001104,1001105,1001106,1001107,1001108, \
                    1001109,1001110,1001111,1001112,1001113,1001114,1001115,1001116,1001117,1001118,1001119,1001120,1001121, \
                    1001122,1001123,1001124,1001125,1001126,1001127,1001128,1001129,1001130,1001131,1001132,1001133,1001134, \
                    1001135,1001136,1001137,1001138,1001139,1001140,1001141,1001142,1001143,1001144,1001145,1001146,1001147, \
                    1001148,1001149,1001150,1001151,1001152,1001153,1001154,1001155,1001156,1001157,1001158,1001159,1001160, \
                    1001161,1001162,1001163,1001164,1001165,1001166,1001167,1001168,1001169,1001170,1001171,1001172,1001173, \
                    1001174,1001175,1001176,1001177,1001178,1001179,1001180,1001181,1001182,1001183,1001184,1001185,1001186, \
                    1001187,1001188,1001189,1001190,1001191,1001192,1001193,1001194,1001195,1001196,1001197,1001198,1001199, \
                    1001200,1001201,1001202,1001203,1001204,1001205,1001206,1001207,1001208,1001209,1001210,1001211,1001212, \
                    1001213,1001214,1001215,1001216,1001217,1001218,1001219,1001220,1001221,1001222,1001223,1001224,1001225 \
                 ) \
           group by name, search_result_url \
         ) t distribute by 1

