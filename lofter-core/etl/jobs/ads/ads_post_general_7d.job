type=sparksql
hive.query.01=insert overwrite table lofter_dm.ads_post_general_7d partition(dt='${azkaban.flow.1.days.ago}') select /*+ MAPJOIN(dim_date_rolling)*/ s.postId, s.blogId, s.blogName, sum(s.hot) hot, sum(s.commendUserCount) commendUserCount, sum(s.commendCount) commendCount, sum(s.praiseCount) praiseCount, sum(s.recommendcount) recommendcount, sum(s.reproduceUserCount) reproduceUserCount, sum(s.subscribeUserCount) subscribeUserCount, sum(s.reproduceCount) reproduceCount,sum(s.subscribeCount) subscribeCount, sum(newHot) newHot, sum(newCommendCount) newCommendCount, avg(hot) avgHot, s.blogNickName, s.contentType, s.citedParentPostId from lofter_dm.ads_post_general_di s join lofter.dim_date_rolling d on s.dt = d.rollingDate where d.id = '${azkaban.flow.1.days.ago}' and d.period = 7 and s.dt >= '${azkaban.flow.7.days.ago}' group by s.postId, s.blogId, s.blogName, s.blogNickName, s.contentType, s.citedParentPostId distribute by 1;
dependencies=ads_post_general_di