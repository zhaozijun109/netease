execution-jar=${classpath}
class=com.netease.lofter.etl.common.ClickhouseLoad
conf.spark.source.query="select * from lofter_dm.ads_post_category_di where dt = '${azkaban.flow.1.days.ago}' "
params=--dest hive.ads_post_category_di --partition '${azkaban.flow.1.days.ago}'
retries=0
dependencies=ads_post_category_di