type=sparksql
hive.query.01=insert overwrite table lofter.dwd_ec_add_cart_di partition(dt = '${azkaban.flow.1.days.ago}') \
    select userId, deviceUdid, occurTime, itemId as productId \
    from lofter.ods_mda_app_partition_di \
    where dt = '${azkaban.flow.1.days.ago}' and actionType = 'benefit_market' and eventId = 'w3-5' \
    distribute by 1
