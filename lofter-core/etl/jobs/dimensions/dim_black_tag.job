      tag like '%萌物%' or tag like '%同人%' or tag like '%摸鱼%' or tag like '%草图%' or \
      tag like '%指绘%' or tag like '%找文%' or tag like '%美女%' or tag like '%同人文%' or \
      tag like '%小说%' or tag like '%漫画%' or tag like '%生活%' or tag like '%搞笑%' or \
      tag like '%有趣%' or tag like '%修图%' or tag like '%摘抄%' or tag like '%日常%' or \
      tag like '%古风%' or tag like '%美食%' or tag like '%可爱%' or tag like '%治愈%' or \
      tag like '%萌宠%' or tag like '%p图%' or tag like '%推文%' or tag like '%图片分享%' or \
