      tag like '%原神好故事%' or tag like '%假期狂享礼%' or tag like '%成就计划%' or tag like '%启明计划%' or \
      tag like '%我的cp报告%' or tag like '%来我作品玩%' or tag like '%在夏有礼%' or tag like '%老福特厨艺大赛%' or \
      tag like '%破镜文学%' or tag like '%替身文学%' or tag like '%追妻文学%' or tag like '%灯塔计划%' or \
