      tag like '%图图计划%' or tag like '%神奇影院%' or tag like '%回家煮面%' or tag like '%玻璃渣爱好者%' or \
      tag like '%我嗑过的cp%' or tag like '%神奇房间%' or tag like '%嗑一口动物塑%' or tag like '%企划%' or \
      tag like '%我的定制%' or tag like '%回礼研究所%' or tag like '%灵感补给站%' or tag like '%剪刀手养成计划%' or \
      tag like '%年夜饭%' or tag like '%QQ人嘉年华%' or tag like '%糖刀PK%' or tag like '%糖刀pk%' or \
      tag like '%梗图嗑一口%' or tag like '%嗑学显微镜%' or tag like '%人间百太%' or tag like '%老福特擦擦节%' or \
      tag like '%万物即可嗑%' or tag like '%对话体%' or tag like '%致歉%' or tag like '%退圈%' or \
      tag like '%声明%' or tag like '%退圈声明%' or tag like '%通知%' or tag like '%美好%' or \
      tag like '%同人小说%' or tag like '%联文%' or tag like '%召回计划%' or tag like '%磕cp%' or \
