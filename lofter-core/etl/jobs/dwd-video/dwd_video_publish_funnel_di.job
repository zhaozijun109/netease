type=sparksql
hive.query.01=insert overwrite table lofter.dwd_video_publish_funnel_di partition(dt='${azkaban.flow.1.days.ago}') \
with publish_video as ( \
    select \
        deviceUdid, \
        userId, \
        deviceOs, \
        deviceModel, \
        appVersion, \
        eventId, \
        occurTime, \
        cast(itemId as bigint)                                     as itemId, \
        scene, \
        params['reqId']                                            as req_id, \
        params['type']                                             as post_type, \
        params['code']                                             as top_code, \
        get_json_object(params['ext'], '$.msg')                    as ext_msg, \
        get_json_object(params['ext'], '$.errorCode')              as ext_error_code \
    from lofter.ods_mda_app_di \
    where dt = '${azkaban.flow.1.days.ago}' \
      and eventId in ('c10-1','c10-5','c10-10','c10-15','c10-30','c10-31','c10-32') \
      and itemType in ('VIDEO','4') \
      and params['reqId'] is not null \
      and params['reqId'] <> '' \
      and length(deviceUdid) > 0 \
) \
select \
    req_id, \
    max(deviceUdid)                                                as deviceUdid, \
    max(userId)                                                    as userId, \
    max(deviceOs)                                                  as deviceOs, \
    max(deviceModel)                                               as deviceModel, \
    max(appVersion)                                                as appVersion, \
    max(itemId)                                                    as itemId, \
    max(case when eventId = 'c10-1' then post_type end)            as post_type, \
    max(case when eventId = 'c10-1' then scene end)                as scene, \
    min(case when eventId = 'c10-1'  then occurTime end)           as start_time, \
    min(case when eventId = 'c10-5'  then occurTime end)           as upload_start_time, \
    max(case when eventId = 'c10-10' then occurTime end)           as upload_progress_time, \
    max(case when eventId = 'c10-15' then occurTime end)           as success_time, \
    max(case when eventId = 'c10-15' then 1 else 0 end)            as is_success, \
    max(case when eventId = 'c10-1'  then 1 else 0 end)            as has_start, \
    max(case when eventId = 'c10-5'  then 1 else 0 end)            as has_upload_start, \
    max(case when eventId = 'c10-10' then 1 else 0 end)            as has_progress, \
    max(case when eventId = 'c10-30' then 1 else 0 end)            as has_intercepted, \
    max(case when eventId = 'c10-31' then 1 else 0 end)            as has_material_fail, \
    max(case when eventId = 'c10-32' then 1 else 0 end)            as has_api_fail, \
    case \
        when max(case when eventId='c10-15' then 1 else 0 end) = 1 then 'Success' \
        when max(case when eventId='c10-32' then 1 else 0 end) = 1 then 'ApiFail' \
        when max(case when eventId='c10-31' then 1 else 0 end) = 1 then 'MaterialFail' \
        when max(case when eventId='c10-30' then 1 else 0 end) = 1 then 'ParamIntercepted' \
        when max(case when eventId='c10-10' then 1 else 0 end) = 1 then 'StuckAtFinalCommit' \
        when max(case when eventId='c10-5'  then 1 else 0 end) = 1 then 'StuckAtUploading' \
        when max(case when eventId='c10-1'  then 1 else 0 end) = 1 then 'StuckAtInit' \
        else 'Unknown' \
    end                                                            as fail_stage, \
    max(case when eventId in ('c10-30','c10-31','c10-32') then ext_msg end)        as fail_msg, \
    max(case when eventId in ('c10-30','c10-31','c10-32') then ext_error_code end) as fail_ext_code, \
    max(case when eventId = 'c10-30' then top_code end)                            as fail_top_code, \
    case \
        when ( \
            (max(case when eventId='c10-30' then ext_msg end) in ('正在自动保存', '请输入日志内容', '正在发布上传', '日志内容已超限，请精简~', '标题长度超限', '请上传图片', '上一篇正在发布', '文字文章无内容', '新发文章无内容', '无图片内容')) \
            or (max(case when eventId='c10-31' then ext_msg end) is not null and max(case when eventId='c10-31' then ext_msg end) rlike '(请求超时|网络|断开|SSL|UnknownHost|connection)') \
            or (max(case when eventId='c10-32' then ext_msg end) is not null and max(case when eventId='c10-32' then ext_msg end) rlike '(请求超时|网络|断开|SSL|UnknownHost|connection)') \
        ) then 'UserInteraction_or_Network' \
        when max(case when eventId='c10-30' then ext_msg end) = '定时发布时间已过' then 'ServerError' \
        when max(case when eventId='c10-32' then 1 else 0 end) = 1 then 'ServerError' \
        when max(case when eventId='c10-31' then 1 else 0 end) = 1 then 'ClientError' \
        else null \
    end                                                            as fail_category, \
    max(case when eventId='c10-15' then occurTime end) \
        - min(case when eventId='c10-1' then occurTime end)        as total_duration_ms \
from publish_video \
group by req_id \
distribute by hash(req_id) % 20
dependencies=
