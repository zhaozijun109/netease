    count(distinct if(datediff(a.day, d.createDate) < 30 and d.createDate <= a.day, d.id, null))as new_30_create_uv \
from ( \
    select m.orderId, m.productId, m.buyerId, m.day, n.supplierId, n.amount, m.ips, m.oneLevel \
    from ( \
        select a.orderId,a.productId,a.buyerId,a.day, nvl(b.oneLevel, 'no') as oneLevel, concat_ws(',', b.ips) as ips \
        from ( \
            select orderId,productId,buyerId,from_unixtime(cast(createTime/1000 as bigint),'yyyy-MM-dd') as day \
            from lofter_db_dump.ods_db_benefit_order_product_nd \
            where from_unixtime(cast(createTime/1000 as bigint),'yyyy-MM-dd') <=  '${azkaban.flow.1.days.ago}' and \
                  datediff('${azkaban.flow.1.days.ago}', from_unixtime(cast(createTime/1000 as bigint),'yyyy-MM-dd')) < 7 and \
                  status in (1,3,4) \
        ) a \
        join ( \
            select productId, category1_name as oneLevel, ips from lofter.dim_benefit_product \
        ) b on a.productId = b.productId \
