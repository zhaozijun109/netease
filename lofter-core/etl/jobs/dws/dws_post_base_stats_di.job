execution-jar=${classpath}
driver-memory=4g
conf.spark.sql.autoBroadcastJoinThreshold=10485760
conf.spark.driver.memory=4g
conf.spark.driver.memoryOverhead=2g
conf.spark.yarn.am.cores=2
conf.spark.dynamicAllocation.maxExecutors=20
conf.spark.sql.broadcastTimeout=1200
class=com.netease.lofter.etl.dws.PostBaseDataStatsJob
params= --date ${azkaban.flow.1.days.ago}
dependencies=dws_post_interaction_di,dws_post_support_di,dws_post_traffic_di
