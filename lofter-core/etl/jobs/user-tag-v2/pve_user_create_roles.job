execution-jar=${classpath}
class=com.netease.lofter.etl.userTag.TagDataHandle2Clickhouse
params=--b_line lofter --tag_type user --dt '${azkaban.flow.1.days.ago}' --tag pve_user_create_roles
retries=0
conf.spark.execute.sql="select userId, \
                               'pve_user_create_roles'                as tag_name, \
                               cat                                  as dim1, \
                               ''                                   as dim2, \
                               ''                                   as dim3, \
                               ''                                   as dim4, \
                               ''                                   as dim5, \
                               value \
                        from lofter_dm.ads_pve_chat_new_users_metric_dd where dt = '${azkaban.flow.1.days.ago}' \
                         and tag = 'pve_user_create_roles' "