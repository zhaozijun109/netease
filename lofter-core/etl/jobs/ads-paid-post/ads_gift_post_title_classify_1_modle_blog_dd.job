      and guanying_postnum / postnum >= 0.35 \
    ) \
    or guanying_postnum >= 25 \
  ) \
  and period = '60日'  and dt='${azkaban.flow.1.days.ago}' \
group by \
  blogid \
union \
select \
  blogid, \
  '观影意愿' as flg, \
  '类型标' as type, \
  0 as mark, \
  '观影' as flg1 \
from \
  lofter_dm.ads_gift_post_title_classify_blog_dd \
where \
  (guanying_postnum >= 3) \
  and period = '60日'  and dt='${azkaban.flow.1.days.ago}' \
group by \
  blogid \
union \
select \
  blogid, \
