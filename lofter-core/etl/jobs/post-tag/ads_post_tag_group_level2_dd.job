type=sparksql
conf.spark.dynamicAllocation.maxExecutors=25
conf.spark.sql.shuffle.partitions=100
hive.query.01=insert overwrite table lofter_dm.ads_post_tag_group_level2_dd partition(dt='${azkaban.flow.1.days.ago}') \
select postId, tag, cat, grp \
from ( \
    select id as postId, 'ALL' as tag, 'ALL' as cat, '1' as grp \
    from lofter.dim_post \
    where isPublished=true and isCitedPost = false \
  union all \
    select postId, '互动量' as tag, 'DAY_1' as cat, \
           case when hd_pv < 50 then '1-50' \
                when hd_pv < 100 then '50-100' \
                when hd_pv < 200 then '100-200' \
                when hd_pv < 500 then '200-500' \
                when hd_pv < 1000 then '500-1k' \
                when hd_pv < 2000 then '1k-2k' \
                when hd_pv < 5000 then '2k-5k' \
                when hd_pv < 10000 then '5k-1w' \
                when hd_pv < 30000 then '1w-3w' \
                when hd_pv < 50000 then '3w-5w' \
                when hd_pv < 100000 then '5w-10w' \
                else '10w及以上' end as grp \
    from ( \
        select postId, nvl(hot_pv,0) + nvl(response_pv,0) + nvl(share_pv,0) as hd_pv \
        from lofter.dws_post_interaction_di \
        where dt = '${azkaban.flow.1.days.ago}' and (nvl(hot_pv,0) + nvl(response_pv,0) + nvl(share_pv,0)) > 0 \
    ) t \
    where hd_pv > 0 \
  union all \
    select postId, '互动量' as tag, 'DAY_7' as cat, \
           case when hd_pv < 50 then '1-50' \
                when hd_pv < 100 then '50-100' \
                when hd_pv < 200 then '100-200' \
                when hd_pv < 500 then '200-500' \
                when hd_pv < 1000 then '500-1k' \
                when hd_pv < 2000 then '1k-2k' \
                when hd_pv < 5000 then '2k-5k' \
                when hd_pv < 10000 then '5k-1w' \
                when hd_pv < 30000 then '1w-3w' \
                when hd_pv < 50000 then '3w-5w' \
                when hd_pv < 100000 then '5w-10w' \
                else '10w及以上' end as grp \
    from ( \
        select postId, nvl(hot_7d,0) + nvl(comment_cnt_7d,0) + nvl(share_cnt_7d,0) as hd_pv \
        from lofter.dws_post_interaction_dd \
        where dt = '${azkaban.flow.1.days.ago}' and (nvl(hot_7d,0) + nvl(comment_cnt_7d,0) + nvl(share_cnt_7d,0)) > 0 \
    ) t \
    where hd_pv > 0 \
  union all \
    select postId, '互动量' as tag, 'DAY_15' as cat, \
           case when hd_pv < 50 then '1-50' \
                when hd_pv < 100 then '50-100' \
                when hd_pv < 200 then '100-200' \
                when hd_pv < 500 then '200-500' \
                when hd_pv < 1000 then '500-1k' \
                when hd_pv < 2000 then '1k-2k' \
                when hd_pv < 5000 then '2k-5k' \
                when hd_pv < 10000 then '5k-1w' \
                when hd_pv < 30000 then '1w-3w' \
                when hd_pv < 50000 then '3w-5w' \
                when hd_pv < 100000 then '5w-10w' \
                else '10w及以上' end as grp \
    from ( \
        select postId, nvl(hot_15d,0) + nvl(comment_cnt_15d,0) + nvl(share_cnt_15d,0) as hd_pv \
        from lofter.dws_post_interaction_dd \
        where dt = '${azkaban.flow.1.days.ago}' and (nvl(hot_15d,0) + nvl(comment_cnt_15d,0) + nvl(share_cnt_15d,0)) > 0 \
    ) t \
    where hd_pv > 0 \
  union all \
    select postId, '互动量' as tag, 'DAY_30' as cat, \
           case when hd_pv < 50 then '1-50' \
                when hd_pv < 100 then '50-100' \
                when hd_pv < 200 then '100-200' \
                when hd_pv < 500 then '200-500' \
                when hd_pv < 1000 then '500-1k' \
                when hd_pv < 2000 then '1k-2k' \
                when hd_pv < 5000 then '2k-5k' \
                when hd_pv < 10000 then '5k-1w' \
                when hd_pv < 30000 then '1w-3w' \
                when hd_pv < 50000 then '3w-5w' \
                when hd_pv < 100000 then '5w-10w' \
                else '10w及以上' end as grp \
    from ( \
        select postId, nvl(hot_30d,0) + nvl(comment_cnt_30d,0) + nvl(share_cnt_30d,0) as hd_pv \
        from lofter.dws_post_interaction_dd \
        where dt = '${azkaban.flow.1.days.ago}' and (nvl(hot_30d,0) + nvl(comment_cnt_30d,0) + nvl(share_cnt_30d,0)) > 0 \
    ) t \
    where hd_pv > 0 \
  union all \
    select postId, '收藏量' as tag, 'DAY_1' as cat, \
           case when collect_cnt_1d < 50 then '1-50' \
                when collect_cnt_1d < 100 then '50-100' \
                when collect_cnt_1d < 200 then '100-200' \
                when collect_cnt_1d < 500 then '200-500' \
                when collect_cnt_1d < 1000 then '500-1k' \
                when collect_cnt_1d < 2000 then '1k-2k' \
                when collect_cnt_1d < 5000 then '2k-5k' \
                when collect_cnt_1d < 10000 then '5k-1w' \
                when collect_cnt_1d < 30000 then '1w-3w' \
                when collect_cnt_1d < 50000 then '3w-5w' \
                when collect_cnt_1d < 100000 then '5w-10w' \
                else '10w及以上' end as grp \
    from lofter.dws_post_interaction_dd \
    where dt = '${azkaban.flow.1.days.ago}' and collect_cnt_1d > 0 \
  union all \
    select postId, '收藏量' as tag, 'DAY_7' as cat, \
           case when collect_cnt_7d < 50 then '1-50' \
                when collect_cnt_7d < 100 then '50-100' \
                when collect_cnt_7d < 200 then '100-200' \
                when collect_cnt_7d < 500 then '200-500' \
                when collect_cnt_7d < 1000 then '500-1k' \
                when collect_cnt_7d < 2000 then '1k-2k' \
                when collect_cnt_7d < 5000 then '2k-5k' \
                when collect_cnt_7d < 10000 then '5k-1w' \
                when collect_cnt_7d < 30000 then '1w-3w' \
                when collect_cnt_7d < 50000 then '3w-5w' \
                when collect_cnt_7d < 100000 then '5w-10w' \
                else '10w及以上' end as grp \
    from lofter.dws_post_interaction_dd \
    where dt = '${azkaban.flow.1.days.ago}' and collect_cnt_7d > 0 \
  union all \
    select postId, '收藏量' as tag, 'DAY_15' as cat, \
           case when collect_cnt_15d < 50 then '1-50' \
                when collect_cnt_15d < 100 then '50-100' \
                when collect_cnt_15d < 200 then '100-200' \
                when collect_cnt_15d < 500 then '200-500' \
                when collect_cnt_15d < 1000 then '500-1k' \
                when collect_cnt_15d < 2000 then '1k-2k' \
                when collect_cnt_15d < 5000 then '2k-5k' \
                when collect_cnt_15d < 10000 then '5k-1w' \
                when collect_cnt_15d < 30000 then '1w-3w' \
                when collect_cnt_15d < 50000 then '3w-5w' \
                when collect_cnt_15d < 100000 then '5w-10w' \
                else '10w及以上' end as grp \
    from lofter.dws_post_interaction_dd \
    where dt = '${azkaban.flow.1.days.ago}' and collect_cnt_15d > 0 \
  union all \
    select postId, '收藏量' as tag, 'DAY_30' as cat, \
           case when collect_cnt_30d < 50 then '1-50' \
                when collect_cnt_30d < 100 then '50-100' \
                when collect_cnt_30d < 200 then '100-200' \
                when collect_cnt_30d < 500 then '200-500' \
                when collect_cnt_30d < 1000 then '500-1k' \
                when collect_cnt_30d < 2000 then '1k-2k' \
                when collect_cnt_30d < 5000 then '2k-5k' \
                when collect_cnt_30d < 10000 then '5k-1w' \
                when collect_cnt_30d < 30000 then '1w-3w' \
                when collect_cnt_30d < 50000 then '3w-5w' \
                when collect_cnt_30d < 100000 then '5w-10w' \
                else '10w及以上' end as grp \
    from lofter.dws_post_interaction_dd \
    where dt = '${azkaban.flow.1.days.ago}' and collect_cnt_30d > 0 \
  union all \
    select postId, '收藏量' as tag, 'DAY_ALL' as cat, \
           case when collect_cnt < 50 then '1-50' \
                when collect_cnt < 100 then '50-100' \
                when collect_cnt < 200 then '100-200' \
                when collect_cnt < 500 then '200-500' \
                when collect_cnt < 1000 then '500-1k' \
                when collect_cnt < 2000 then '1k-2k' \
                when collect_cnt < 5000 then '2k-5k' \
                when collect_cnt < 10000 then '5k-1w' \
                when collect_cnt < 30000 then '1w-3w' \
                when collect_cnt < 50000 then '3w-5w' \
                when collect_cnt < 100000 then '5w-10w' \
                else '10w及以上' end as grp \
    from lofter.dws_post_interaction_dd \
    where dt = '${azkaban.flow.1.days.ago}' and collect_cnt > 0 \
  union all \
    select postId, '分享量' as tag, 'DAY_1' as cat, \
           case when share_cnt_1d < 50 then '1-50' \
                when share_cnt_1d < 100 then '50-100' \
                when share_cnt_1d < 200 then '100-200' \
                when share_cnt_1d < 500 then '200-500' \
                when share_cnt_1d < 1000 then '500-1k' \
                when share_cnt_1d < 2000 then '1k-2k' \
                when share_cnt_1d < 5000 then '2k-5k' \
                when share_cnt_1d < 10000 then '5k-1w' \
                when share_cnt_1d < 30000 then '1w-3w' \
                when share_cnt_1d < 50000 then '3w-5w' \
                when share_cnt_1d < 100000 then '5w-10w' \
