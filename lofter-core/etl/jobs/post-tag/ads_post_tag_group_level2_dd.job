                when browse_uv_7d < 2000 then '1k-2k' \
                when browse_uv_7d < 5000 then '2k-5k' \
                when browse_uv_7d < 10000 then '5k-1w' \
                when browse_uv_7d < 30000 then '1w-3w' \
                when browse_uv_7d < 50000 then '3w-5w' \
                when browse_uv_7d < 100000 then '5w-10w' \
                else '10w及以上' end as grp \
    from lofter.dws_post_traffic_dd \
    where dt = '${azkaban.flow.1.days.ago}' and browse_uv_7d > 0 \
  union all \
    select postId, '浏览uv' as tag, 'DAY_15' as cat, \
           case when browse_uv_15d < 50 then '1-50' \
                when browse_uv_15d < 100 then '50-100' \
                when browse_uv_15d < 200 then '100-200' \
                when browse_uv_15d < 500 then '200-500' \
                when browse_uv_15d < 1000 then '500-1k' \
                when browse_uv_15d < 2000 then '1k-2k' \
                when browse_uv_15d < 5000 then '2k-5k' \
                when browse_uv_15d < 10000 then '5k-1w' \
                when browse_uv_15d < 30000 then '1w-3w' \
                when browse_uv_15d < 50000 then '3w-5w' \
                when browse_uv_15d < 100000 then '5w-10w' \
                else '10w及以上' end as grp \
    from lofter.dws_post_traffic_dd \
    where dt = '${azkaban.flow.1.days.ago}' and browse_uv_15d > 0 \
  union all \
    select postId, '浏览uv' as tag, 'DAY_30' as cat, \
           case when browse_uv_30d < 50 then '1-50' \
                when browse_uv_30d < 100 then '50-100' \
                when browse_uv_30d < 200 then '101-200' \
                when browse_uv_30d < 500 then '201-500' \
                when browse_uv_30d < 1000 then '501-1k' \
                when browse_uv_30d < 2000 then '1k-2k' \
                when browse_uv_30d < 5000 then '2k-5k' \
                when browse_uv_30d < 10000 then '5k-1w' \
                when browse_uv_30d < 30000 then '1w-3w' \
                when browse_uv_30d < 50000 then '3w-5w' \
                when browse_uv_30d < 100000 then '5w-10w' \
                else '10w及以上' end as grp \
    from lofter.dws_post_traffic_dd \
    where dt = '${azkaban.flow.1.days.ago}' and browse_uv_30d > 0 \
  union all \
    select postId, '浏览uv' as tag, 'DAY_ALL' as cat, \
               case when realBrowseUv < 50 then '1-50' \
                    when realBrowseUv < 100 then '50-100' \
                    when realBrowseUv < 200 then '100-200' \
                    when realBrowseUv < 500 then '200-500' \
                    when realBrowseUv < 1000 then '501-1k' \
                    when realBrowseUv < 2000 then '1k-2k' \
                    when realBrowseUv < 5000 then '2k-5k' \
                    when realBrowseUv < 10000 then '5k-1w' \
                    when realBrowseUv < 30000 then '1w-3w' \
                    when realBrowseUv < 50000 then '3w-5w' \
                    when realBrowseUv < 100000 then '5w-10w' \
                    else '10w及以上' end as grp \
    from lofter.dws_post_base_stats_dd \
    where dt = '${azkaban.flow.1.days.ago}' and realBrowseUv > 0 \
  union all \
    select postId, '长评数量' as tag, 'DAY_1' as cat, \
           case when long_comment_cnt_1d < 5 then '1-5' \
                when long_comment_cnt_1d < 10 then '5-10' \
                when long_comment_cnt_1d < 20 then '10-20' \
                when long_comment_cnt_1d < 50 then '20-50' \
                when long_comment_cnt_1d < 100 then '50-100' \
                when long_comment_cnt_1d < 200 then '100-200' \
                else '200及以上' end as grp \
    from lofter.dws_post_interaction_dd \
    where dt = '${azkaban.flow.1.days.ago}' and long_comment_cnt_1d > 0 \
  union all \
    select postId, '长评数量' as tag, 'DAY_7' as cat, \
           case when long_comment_cnt_7d < 5 then '1-5' \
                when long_comment_cnt_7d < 10 then '5-10' \
                when long_comment_cnt_7d < 20 then '10-20' \
                when long_comment_cnt_7d < 50 then '20-50' \
                when long_comment_cnt_7d < 100 then '50-100' \
                when long_comment_cnt_7d < 200 then '100-200' \
                else '200及以上' end as grp \
    from lofter.dws_post_interaction_dd \
    where dt = '${azkaban.flow.1.days.ago}' and long_comment_cnt_7d > 0 \
  union all \
    select postId, '长评数量' as tag, 'DAY_15' as cat, \
           case when long_comment_cnt_15d < 5 then '1-5' \
                when long_comment_cnt_15d < 10 then '5-10' \
                when long_comment_cnt_15d < 20 then '10-20' \
                when long_comment_cnt_15d < 50 then '20-50' \
                when long_comment_cnt_15d < 100 then '50-100' \
                when long_comment_cnt_15d < 200 then '100-200' \
                else '200及以上' end as grp \
    from lofter.dws_post_interaction_dd \
    where dt = '${azkaban.flow.1.days.ago}' and long_comment_cnt_15d > 0 \
  union all \
    select postId, '长评数量' as tag, 'DAY_30' as cat, \
           case when long_comment_cnt_30d < 5 then '1-5' \
                when long_comment_cnt_30d < 10 then '5-10' \
                when long_comment_cnt_30d < 20 then '10-20' \
                when long_comment_cnt_30d < 50 then '20-50' \
                when long_comment_cnt_30d < 100 then '50-100' \
                when long_comment_cnt_30d < 200 then '100-200' \
                else '200及以上' end as grp \
    from lofter.dws_post_interaction_dd \
    where dt = '${azkaban.flow.1.days.ago}' and long_comment_cnt_30d > 0 \
  union all \
    select postId, '长评数量' as tag, 'DAY_ALL' as cat, \
           case when long_comment_cnt_std < 5 then '1-5' \
                when long_comment_cnt_std < 10 then '5-10' \
                when long_comment_cnt_std < 20 then '10-20' \
                when long_comment_cnt_std < 50 then '20-50' \
                when long_comment_cnt_std < 100 then '50-100' \
                when long_comment_cnt_std < 200 then '100-200' \
                else '200及以上' end as grp \
    from lofter.dws_post_interaction_dd \
    where dt = '${azkaban.flow.1.days.ago}' and long_comment_cnt_std > 0 \
  union all \
    select content_id as postId, '拉新量' as tag, 'DAY_1' as cat, \
           case when new_devices < 10 then '1-10' \
                when new_devices < 50 then '10-50' \
                when new_devices < 100 then '50-100' \
                when new_devices < 200 then '100-200' \
                when new_devices < 500 then '200-500' \
                when new_devices < 1000 then '500-1k' \
                when new_devices < 2000 then '1k-2k' \
                when new_devices < 5000 then '2k-5k' \
                when new_devices < 10000 then '5k-1w' \
                when new_devices < 30000 then '1w-3w' \
                else '3w以上' end as grp \
    from lofter_dm.ads_growth_content_di \
    where dt = '${azkaban.flow.1.days.ago}' and new_devices > 0 and \
          content_type in ('图片', '文字', '视频') \
  union all \
    select content_id as postId, '拉新量' as tag, 'DAY_7' as cat, \
           case when new_devices_7d < 10 then '1-10' \
                when new_devices_7d < 50 then '10-50' \
                when new_devices_7d < 100 then '50-100' \
                when new_devices_7d < 200 then '100-200' \
                when new_devices_7d < 500 then '200-500' \
                when new_devices_7d < 1000 then '500-1k' \
                when new_devices_7d < 2000 then '1k-2k' \
                when new_devices_7d < 5000 then '2k-5k' \
                when new_devices_7d < 10000 then '5k-1w' \
                when new_devices_7d < 30000 then '1w-3w' \
                else '3w以上' end as grp \
    from lofter_dm.ads_growth_content_di \
    where dt = '${azkaban.flow.1.days.ago}' and new_devices_7d > 0 and \
          content_type in ('图片', '文字', '视频') \
  union all \
    select content_id as postId, '拉新量' as tag, 'DAY_30' as cat, \
           case when new_devices_30d < 10 then '1-10' \
                when new_devices_30d < 50 then '10-50' \
                when new_devices_30d < 100 then '50-100' \
                when new_devices_30d < 200 then '100-200' \
                when new_devices_30d <= 500 then '200-500' \
                when new_devices_30d < 1000 then '500-1k' \
                when new_devices_30d < 2000 then '1k-2k' \
                when new_devices_30d < 5000 then '2k-5k' \
                when new_devices_30d < 10000 then '5k-1w' \
                when new_devices_30d < 30000 then '1w-3w' \
                else '3w以上' end as grp \
    from lofter_dm.ads_growth_content_di \
    where dt = '${azkaban.flow.1.days.ago}' and new_devices_30d > 0 and \
          content_type in ('图片', '文字', '视频') \
  union all \
    select content_id as postId, '拉新量' as tag, 'DAY_15' as cat, \
           case when new_devices_30d < 10 then '1-10' \
                when new_devices_30d < 50 then '10-50' \
                when new_devices_30d < 100 then '50-100' \
                when new_devices_30d < 200 then '100-200' \
                when new_devices_30d <= 500 then '200-500' \
                when new_devices_30d < 1000 then '500-1k' \
                when new_devices_30d < 2000 then '1k-2k' \
                when new_devices_30d < 5000 then '2k-5k' \
                when new_devices_30d < 10000 then '5k-1w' \
                when new_devices_30d < 30000 then '1w-3w' \
                else '3w以上' end as grp \
    from lofter_dm.ads_growth_content_di \
    where dt = '${azkaban.flow.1.days.ago}' and new_devices_15d > 0 and \
          content_type in ('图片', '文字', '视频') \
  union all \
    select content_id as postId, '拉新量' as tag, 'DAY_ALL' as cat, \
           case when new_devices_std < 10 then '1-10' \
                when new_devices_std < 50 then '10-50' \
                when new_devices_std < 100 then '50-100' \
                when new_devices_std < 200 then '100-200' \
                when new_devices_std < 500 then '200-500' \
                when new_devices_std < 1000 then '500-1k' \
                when new_devices_std < 2000 then '1k-2k' \
                when new_devices_std < 5000 then '2k-5k' \
                when new_devices_std < 10000 then '5k-1w' \
                when new_devices_std < 30000 then '1w-3w' \
                else '3w以上' end as grp \
    from lofter_dm.ads_growth_content_di \
    where dt = '${azkaban.flow.1.days.ago}' and new_devices_std > 0 and \
          content_type in ('图片', '文字', '视频') \
) t \
distribute by (postId / 1000000) % 100 \
sort by tag, cat, grp, postId
