    from lofter.dws_post_interaction_dd \
    where dt = '${azkaban.flow.1.days.ago}' and share_cnt_15d > 0 \
  union all \
    select postId, '分享量' as tag, 'DAY_30' as cat, \
           case when share_cnt_30d < 50 then '1-50' \
                when share_cnt_30d < 100 then '50-100' \
                when share_cnt_30d < 200 then '100-200' \
                when share_cnt_30d < 500 then '200-500' \
                when share_cnt_30d < 1000 then '500-1k' \
                when share_cnt_30d < 2000 then '1k-2k' \
                when share_cnt_30d < 5000 then '2k-5k' \
                when share_cnt_30d < 10000 then '5k-1w' \
                when share_cnt_30d < 30000 then '1w-3w' \
                when share_cnt_30d < 50000 then '3w-5w' \
                when share_cnt_30d < 100000 then '5w-10w' \
                else '10w及以上' end as grp \
    from lofter.dws_post_interaction_dd \
    where dt = '${azkaban.flow.1.days.ago}' and share_cnt_30d > 0 \
  union all \
    select postId, '分享量' as tag, 'DAY_ALL' as cat, \
           case when sharePv < 50 then '1-50' \
                when sharePv < 100 then '50-100' \
                when sharePv < 200 then '100-200' \
                when sharePv < 500 then '200-500' \
                when sharePv < 1000 then '500-1k' \
                when sharePv < 2000 then '1k-2k' \
                when sharePv < 5000 then '2k-5k' \
                when sharePv < 10000 then '5k-1w' \
                when sharePv < 30000 then '1w-3w' \
                when sharePv < 50000 then '3w-5w' \
                when sharePv < 100000 then '5w-10w' \
                else '10w及以上' end as grp \
    from lofter.dws_post_base_stats_dd \
    where dt = '${azkaban.flow.1.days.ago}' and sharePv > 0 \
  union all \
    select postId, '点赞量' as tag, 'DAY_1' as cat, \
           case when like_cnt_1d < 50 then '1-50' \
                when like_cnt_1d < 100 then '50-100' \
                when like_cnt_1d < 200 then '100-200' \
                when like_cnt_1d < 500 then '200-500' \
                when like_cnt_1d < 1000 then '500-1k' \
                when like_cnt_1d < 2000 then '1k-2k' \
                when like_cnt_1d < 5000 then '2k-5k' \
                when like_cnt_1d < 10000 then '5k-1w' \
                when like_cnt_1d < 30000 then '1w-3w' \
                when like_cnt_1d < 50000 then '3w-5w' \
                when like_cnt_1d < 100000 then '5w-10w' \
                else '10w及以上' end as grp \
    from lofter.dws_post_interaction_dd \
