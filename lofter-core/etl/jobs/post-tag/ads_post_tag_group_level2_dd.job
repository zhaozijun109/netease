    from lofter.dws_post_interaction_dd \
    where dt = '${azkaban.flow.1.days.ago}' and share_cnt_7d > 0 \
  union all \
    select postId, '分享量' as tag, 'DAY_15' as cat, \
           case when share_cnt_15d < 50 then '1-50' \
