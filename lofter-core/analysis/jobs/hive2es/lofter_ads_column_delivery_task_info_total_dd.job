execution-jar=${classpath}
class=com.netease.lofter.data.common.Hive2ES
conf.spark.source.query="select concat_ws('_', a.colTaskId, a.columnId) as id, a.`colTaskId`,a.`columnId`,a.`scenes`,a.`exposureCount`,a.`clickCount`,a.`clickRateCount`,a.`dt` from (select * from `lofter_dm`.`ads_column_delivery_task_info_total_dd` where dt='${azkaban.flow.1.days.ago}') a join (select colTaskId from `lofter_dm`.`ads_column_delivery_task_info_di` where dt = '${azkaban.flow.1.days.ago}' group by colTaskId) b on a.colTaskId = b.colTaskId"
params= --partition ${azkaban.flow.1.days.ago} --id id --dest lofter_ads_column_delivery_task_info_total_dd --postfixsep --atom