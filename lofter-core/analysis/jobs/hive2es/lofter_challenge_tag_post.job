execution-jar=${classpath}
class=com.netease.lofter.data.common.Hive2ES
conf.spark.source.query="select concat_ws('_',challenge_tag,rank,role_tag,postId) as id, date, role_tag as roleTag, challenge_tag as challengeTag, postId, blogId, incrementHot, showChallengeTag from lofter_dm.ads_summer_act_challenge_hot_post_list_di where dt = '${azkaban.flow.1.days.ago}' and role_tag is not null "
params= --partition ${azkaban.flow.1.days.ago} --url lofter-online-es1.gy.ntes:7000,lofter-online-es2.gy.ntes:7000,lofter-online-es3.gy.ntes:7000,lofter-online-es4.gy.ntes:7000 --username lofter_online --password Yi3DLCppSI --dest lofter_challenge_tag_post --id id --postfixsep --full --atom --parallel 1