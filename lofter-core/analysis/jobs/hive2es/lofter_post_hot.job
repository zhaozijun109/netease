execution-jar=${classpath}
class=com.netease.lofter.data.common.Hive2ES
conf.spark.source.query="select postId as id, hot_std as hot, hot_7d as recent7hot, hot_1d as recent1hot from lofter_dm.ads_post_hot_dd where dt='${azkaban.flow.1.days.ago}' and (hot_7d_diff != 0 or hot_1d_diff != 0)"
params= --dest lofter_post --update --url lofter-online-es1.gy.ntes:7000,lofter-online-es2.gy.ntes:7000,lofter-online-es3.gy.ntes:7000,lofter-online-es4.gy.ntes:7000 --username lofter_online --password Yi3DLCppSI --parallel 2
