execution-jar=${classpath}
class=com.netease.lofter.data.common.Hive2ES
conf.spark.source.query="select concat(replace(dt, '-'), '_', tag) as id, tag, dt as date, subscribeCount, subscribeCount7, subscribeCount30, unsubscribeCount, unsubscribeCount7, unsubscribeCount30,postCount, postCount7, postCount30,hot, hot7, hot30,pv, pv7, pv30,clientTagBrowsingCount, pcTagBrowsingCount, h5TagBrowsingCount,wechatFriendsShareCount, wechatFriendsCircleShareCount, wechatWeiboShareCount,wechatQQFriendsShareCount, wechatQQSpaceShareCount,isCold from lofter_dm.ads_tag_flat_di where dt='${azkaban.flow.1.days.ago}' and length(tag) > 0 and length(tag) < 250 and  octet_length(tag)<=503"
params= --partition ${azkaban.flow.1.days.ago} --dest lofter_tags_daily --postfixsep --partitionPrefix lofter_tags --full --atom --url lofter-online-es1.gy.ntes:7000,lofter-online-es2.gy.ntes:7000,lofter-online-es3.gy.ntes:7000,lofter-online-es4.gy.ntes:7000 --username lofter_online --password Yi3DLCppSI --parallel 2
