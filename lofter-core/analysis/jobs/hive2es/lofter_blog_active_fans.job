execution-jar=${classpath}
class=com.netease.lofter.data.common.Hive2ES
conf.spark.source.query="select concat(blogId, '_', userId) as id, blogId, userId from lofter_dm.ads_creator_active_fans_dd where dt='${azkaban.flow.1.days.ago}' "
params= --partition ${azkaban.flow.1.days.ago} --dest lofter_blog_active_fans --full --atom
