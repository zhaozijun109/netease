execution-jar=${classpath}
class=com.netease.lofter.data.common.Hive2ES
conf.spark.source.query="select blogId as id,blogId,wordNum,photoNum,videoNum,postNumAvg,tagNum,favoriteTag,favoriteTagPostNum,favoriteTagUv,commentNum,giftMoney,rewardMoney,dunUv,giftTopPostId,giftTopMoney,rewardTopPostId,rewardTopMoney,grainNum,dt  from lofter_dm.ads_user_data_center_dd where dt='${azkaban.flow.1.days.ago}' "
params= --partition ${azkaban.flow.1.days.ago} --parallel 5 --url lofter-online-es1.gy.ntes:7000,lofter-online-es2.gy.ntes:7000,lofter-online-es3.gy.ntes:7000,lofter-online-es4.gy.ntes:7000 --username lofter_online --password Yi3DLCppSI --dest lofter_creator_center_dd --postfixsep --full --atom