execution-jar=${classpath}
class=com.netease.lofter.data.common.Hive2ES
conf.spark.source.query="SELECT concat_ws(':', itemId,itemType) as id,itemId,itemType,tags,totalOrderCount,totalOrderSales,recent7DaysOrderCount,recent7DaysOrderSales FROM `lofter_dm`.`ads_image_market_product_stat_dd` WHERE dt = '${azkaban.flow.1.days.ago}'"
params= --partition ${azkaban.flow.1.days.ago} --id id --dest image_market_product_stat --postfixsep --full --atom --url lofter-online-es1.gy.ntes:7000,lofter-online-es2.gy.ntes:7000,lofter-online-es3.gy.ntes:7000,lofter-online-es4.gy.ntes:7000 --username lofter_online --password Yi3DLCppSI