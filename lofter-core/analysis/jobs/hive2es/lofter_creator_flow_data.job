execution-jar=${classpath}
class=com.netease.lofter.data.common.Hive2ES
conf.spark.source.query="select blogId, sevenDayFlowRate, thirtyDayFlowRate, sevenDayDiscoveryPercent, sevenDayTagPercent, sevenDayCollectionPercent, sevenDayOtherPercent, thirtyDayDiscoveryPercent, thirtyDayTagPercent, thirtyDayCollectionPercent, thirtyDayOtherPercent, flowSourceType, sevenDayNewFlowRate, sevenDayBackFlowRate, thirtyDayNewFlowRate, thirtyDayBackFlowRate from lofter_dm.ads_creator_ecology_traffic_stats_dd where dt = '${azkaban.flow.1.days.ago}'"
params= --partition ${azkaban.flow.1.days.ago} --id blogId --dest lofter_creator_flow_data --postfixsep --full --atom --url lofter-online-es1.gy.ntes:7000,lofter-online-es2.gy.ntes:7000,lofter-online-es3.gy.ntes:7000,lofter-online-es4.gy.ntes:7000 --username lofter_online --password Yi3DLCppSI --parallel 1