execution-jar=${classpath}
class=com.netease.lofter.data.common.Hive2ES
conf.spark.source.query="select userId, top_tags_with_pv as hotTagsWithPv, top_tags as hotTags from lofter_dm.ads_par_user_tag_top_browse_di where dt='${azkaban.flow.1.days.ago}' "
params= --id userId --partition ${azkaban.flow.1.days.ago} --dest lofter_user_top_tag --full --atom --url lofter-online-es1.gy.ntes:7000,lofter-online-es2.gy.ntes:7000,lofter-online-es3.gy.ntes:7000,lofter-online-es4.gy.ntes:7000 --username lofter_online --password Yi3DLCppSI --parallel 2
