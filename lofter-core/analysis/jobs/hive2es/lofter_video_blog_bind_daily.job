execution-jar=${classpath}
class=com.netease.lofter.data.common.Hive2ES
conf.spark.source.query="select concat(replace(dt, '-'), '-',orgId,'-',blogId) as id,dt,orgId,blogId,playNum,realPlayNum,likeNum,recommendNum,commentNum,hotNum from lofter_dm.ads_video_blog_bind_di where dt = '${azkaban.flow.1.days.ago}'"
params= --dest lofter_video_blog_bind_daily
