execution-jar=${classpath}
class=com.netease.lofter.data.common.Hive2Kafka
conf.spark.source.query="select userId, new_fans from lofter_dm.ads_push_follow_notice_1100_di where dt='${azkaban.flow.current.date}' "
params= --topic lofter.push.follow.notice  --servers lofter-kafka-dc1.gy.ntes:9092,lofter-kafka-dc2.gy.ntes:9092,lofter-kafka-dc3.gy.ntes:9092
dependencies=ads_push_follow_notice_1100_di