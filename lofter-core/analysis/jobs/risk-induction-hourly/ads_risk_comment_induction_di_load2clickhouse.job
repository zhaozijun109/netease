execution-jar=${classpath}
class=com.netease.lofter.data.common.ClickhouseLoad
conf.spark.source.query="select dt, content, pv from lofter_dm.ads_risk_comment_induction_di where dt = '${azkaban.flow.current.date}' "
params=--dest hive.ads_risk_comment_induction_di --partition '${azkaban.flow.current.date}'
retries=0
dependencies=ads_risk_comment_induction_di
