execution-jar=${classpath}
conf.spark.dynamicAllocation.maxExecutors=5
conf.spark.executor.cores=2
class=com.netease.lofter.data.common.ClickhouseLoad
conf.spark.source.query="select dt,tags,action_date,postid,blogid,is_first_published,is_new_register,is_return_published,is_daren,is_premium,level,is_premium_post,is_next_day_retain,is_shua,shua_hot,publish_time,recomstatus,post_main_content_type,post_url,authdomain_names,blogname,fans_std,post_count_std,post_content_type,title,total_hot,commend_count,praise_count,reproduce_count,recommend_count,subscribe_count,exposed_count,click_count,rec_exposed_count,tag_rec_exposed_count,feed_rec_exposed_count,cold_start_rec_exposed_count,return_gift_plantype,free_gift_send_post_uv,free_gift_post_pv,paid_gift_send_post_uv,pay_gift_money_post_amount,is_paid_premium_post,blog_url,domain_r1,pre_fans_cnt,current_fans_cnt,isreturngiftsetblog,free_gift_send_blog_uv,free_gift_blog_pv,paid_gift_send_blog_uv,pay_gift_money_blog_amount,blognickname,words_count,photo_count,return_gift_words_count,return_gift_photo_count,ispay_returngift,ips,sourcetype,unlock_uv_with_candy_coupon,unlock_money_with_candy_coupon,after_published_7_days_amount,after_published_7_days_hot,first_published_date,last_published_date,paid_post_count,post_top_ips,post_top_tags,post_top10_ips,post_top10_tags,after_published_15_days_hot,after_published_30_days_hot,after_published_7_days_valid_comment_uv,after_published_15_days_valid_comment_uv,after_published_30_days_valid_comment_uv,after_published_60_days_valid_comment_uv, is_c2c_product_post from lofter_dm.ads_tag_easy_fetch_activity_01_dd where dt = '${azkaban.flow.1.days.ago}' "
params=--dest hive.ads_tag_easy_fetch_activity_01_dd --partition '${azkaban.flow.1.days.ago}' --parallel 50 --batch 10000
retries=0
dependencies=ads_tag_easy_fetch_activity_01_dd
