execution-jar=${classpath}
class=com.netease.lofter.data.common.ClickhouseLoad
conf.spark.source.query="select dt,userid,register_date,total_collection_subscribe_pv,total_follow_uv,all_post_browse_cnt,free_picture_post_browse_cnt,free_words_post_browse_cnt,pay_picture_post_browse_cnt,pay_words_post_browse_cnt,all_post_gift_cnt,words_post_gift_cnt,picture_post_gift_cnt,all_1d_money,pay_gift_1d_money,pve_1d_money,coupon_card_1d_money,fans_vip_1d_money,book_vip_1d_money,market_1d_money,lottery_1d_money,all_total_money,pay_gift_total_money,pve_total_money,coupon_card_total_money,fans_vip_total_money,book_vip_total_money,market_total_money,lottery_total_money,1d_gift_level,7d_gift_level,30d_gift_level,is_high_willing_pay_user,refuse_pay_user,1d_gift_money,7d_gift_money,30d_gift_money,active_type,grain_unlock_pv,coupon_unlock_pv,coin_balance,recharge_money_1d,coupon_balance_new_1d,top_ips,subscribe_unlock_post_count,zhengfankui_pv,fufankui_pv,pay_top_ips,user_homepage,pay_top_types_1d,pay_top_sells_1d,pay_top_types_7d,pay_top_sells_7d,article_unlock_times_0d,article_unlock_times_30d,article_unlock_times_90d,article_unlock_money_0d,article_unlock_money_30d,picture_unlock_money_0d,picture_unlock_money_30d,dress_unlock_money_0d,dress_unlock_money_30d,paid_post_valid_pv_30d,paid_post_amount_30d,ip_paid_post_valid_pv_30d,ip_paid_post_amount_30d,total_pay_amount_1d,valid_pay_browse_pv_1d,coin_recharge_amount_1d,coupon_buy_amount_1d from lofter_dm.ads_gift_easy_fetch_user_di where dt = '${azkaban.flow.1.days.ago}' "
params=--dest hive.ads_gift_easy_fetch_user_di --partition '${azkaban.flow.1.days.ago}' --batch 2000
retries=0
dependencies=ads_gift_easy_fetch_user_di