execution-jar=${classpath}
class=com.netease.lofter.data.common.Hive2Kafka
conf.spark.source.query="select actionId, amount from lofter.dwd_ad_growth_order_activate_di where dt='${azkaban.flow.1.days.ago}'"
params= --topic LOFTER.ASO.PAYFORACTIVE --servers　lofter-kafka-dc1.gy.ntes:9092,lofter-kafka-dc2.gy.ntes:9092,lofter-kafka-dc3.gy.ntes:9092
