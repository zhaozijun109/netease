execution-jar=${classpath}
class=com.netease.lofter.data.common.Hive2Kafka
conf.spark.source.query="select userId from lofter_dm.ads_im_user_match_di where dt = '${azkaban.flow.1.days.ago}' "
params= --topic LOFTER.IM.user.math --servers lofter-kafka-dc1.gy.ntes:9092,lofter-kafka-dc2.gy.ntes:9092,lofter-kafka-dc3.gy.ntes:9092
