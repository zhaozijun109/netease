type=sparksql
hive.query.01=insert overwrite table lofter_dm.ads_push_task_pool_di partition(dt = '${azkaban.flow.current.date}', executionId= 'user_tag_tx') \
select userId, \
       'LOFTER.PUSH.NEW.TASK' as push_topic, \
       to_json(struct(*)) as push_params, \
       'user_tag_tx' as policy, \
       1 as priority, \
       unix_timestamp()*1000L as create_time \
from ( \
    select userId, 24 as messageType, blogId, postId as itemId, content \
    from lofter_dm.ads_push_user_tag_tx_di \
    where dt = '${azkaban.flow.current.date}' \
) t \

dependencies=ads_push_user_tag_tx_di
