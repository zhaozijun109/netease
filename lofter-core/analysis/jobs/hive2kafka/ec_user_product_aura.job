execution-jar=${classpath}
class=com.netease.lofter.data.common.Hive2Kafka
conf.spark.source.query="select userId, type, productId, cardActivityCode as activityCode, auraType from lofter_dm.ads_ec_user_product_aura_dd where dt = '${azkaban.flow.1.days.ago}'"
params= --topic LOFTER.MARKET.USER.PRODUCT.AURA --servers lofter-kafka-dc1.gy.ntes:9092,lofter-kafka-dc2.gy.ntes:9092,lofter-kafka-dc3.gy.ntes:9092
