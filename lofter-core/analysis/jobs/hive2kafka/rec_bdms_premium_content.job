execution-jar=${classpath}
class=com.netease.lofter.data.common.Hive2Kafka
conf.spark.source.query="select postId from lofter_dm.ads_risk_rec_review_retrospect_di where dt = '${azkaban.flow.1.days.ago}' "
params= --topic rec_bdms_premium_content --servers lofter-kafka-recommend1.gy.ntes:9092,lofter-kafka-recommend2.gy.ntes:9092,lofter-kafka-recommend3.gy.ntes:9092
