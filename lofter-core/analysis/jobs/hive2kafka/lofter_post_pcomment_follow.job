execution-jar=${classpath}
class=com.netease.lofter.data.common.Hive2Kafka
conf.spark.source.query="select postId, pid, content, followedCount from lofter_dm.ads_post_comment_duplication_dd where dt = '${azkaban.flow.1.days.ago}'"
params= --topic lofter.post.pcomment.follow --servers lofter-kafka-dc1.gy.ntes:9092,lofter-kafka-dc2.gy.ntes:9092,lofter-kafka-dc3.gy.ntes:9092
