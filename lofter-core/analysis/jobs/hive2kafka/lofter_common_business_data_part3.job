execution-jar=${classpath}
class=com.netease.lofter.data.common.Hive2KafkaPayload
conf.spark.source.query="select postId, blogId, top_pids as topPids from lofter_dm.ads_post_highlight_comment_top_di where dt = '${azkaban.flow.1.days.ago}' "
params=  --messageType 3 --topic lofter.common.businessData --servers lofter-kafka-dc1.gy.ntes:9092,lofter-kafka-dc2.gy.ntes:9092,lofter-kafka-dc3.gy.ntes:9092 --parallel 1
