execution-jar=${classpath}
class=com.netease.lofter.data.common.Hive2Kafka
conf.spark.source.query=" \
select postId, type \
from lofter_dm.ads_creator_newback_traffic_support_di \
where dt = '${azkaban.flow.1.days.ago}' \
"
params= --topic lofter.newback.traffic.support --servers lofter-kafka-dc1.gy.ntes:9092,lofter-kafka-dc2.gy.ntes:9092,lofter-kafka-dc3.gy.ntes:9092 --parallel 1