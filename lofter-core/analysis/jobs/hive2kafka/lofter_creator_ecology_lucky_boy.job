execution-jar=${classpath}
class=com.netease.lofter.data.common.Hive2Kafka
conf.spark.source.query="SELECT userId FROM lofter_dm.ads_creator_ecology_lucky_boy_dd WHERE dt = '${azkaban.flow.1.days.ago}' limit 100"
params= --topic LOFTER.COMMON.ADMIN.LUCKY.BOY --servers lofter-kafka-dc1.gy.ntes:9092,lofter-kafka-dc2.gy.ntes:9092,lofter-kafka-dc3.gy.ntes:9092