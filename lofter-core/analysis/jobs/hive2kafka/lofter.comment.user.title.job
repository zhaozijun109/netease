execution-jar=${classpath}
class=com.netease.lofter.data.common.Hive2Kafka
conf.spark.source.query="select blogId as userId, title from lofter_dm.ads_act_comment_blog_title_di where dt = '${azkaban.flow.1.days.ago}'"
params= --topic lofter.comment.user.title --servers lofter-kafka-dc1.gy.ntes:9092,lofter-kafka-dc2.gy.ntes:9092,lofter-kafka-dc3.gy.ntes:9092