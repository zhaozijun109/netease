execution-jar=${classpath}
class=com.netease.lofter.data.common.Hive2Kafka
conf.spark.source.query="select postId, blogId, totalUserNum, totalCount, pids from lofter_dm.ads_post_usermark_stats_di where dt = '${azkaban.flow.1.days.ago}' "
params= --topic pcomment.usermark.notice --servers lofter-kafka-dc1.gy.ntes:9092,lofter-kafka-dc2.gy.ntes:9092,lofter-kafka-dc3.gy.ntes:9092
