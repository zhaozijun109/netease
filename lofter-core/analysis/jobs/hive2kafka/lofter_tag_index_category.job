execution-jar=${classpath}
class=com.netease.lofter.data.common.Hive2Kafka
conf.spark.source.query="select postId, blogId, category, sourceType from lofter_dm.ads_ecology_tag_index_category_di where dt = '${azkaban.flow.1.days.ago}' "
params= --topic lofter.tag.index.category --servers lofter-kafka-dc1.gy.ntes:9092,lofter-kafka-dc2.gy.ntes:9092,lofter-kafka-dc3.gy.ntes:9092
