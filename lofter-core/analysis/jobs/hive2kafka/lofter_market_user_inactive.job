execution-jar=${classpath}
class=com.netease.lofter.data.common.Hive2Kafka
conf.spark.source.query="select userId, streak_inactive_days as inactiveDays from lofter_dm.ads_ec_user_streak_inactive_days_di where dt = '${azkaban.flow.1.days.ago}' "
params= --topic LOFTER.MARKET.USER.INACTIVE --servers lofter-kafka-dc1.gy.ntes:9092,lofter-kafka-dc2.gy.ntes:9092,lofter-kafka-dc3.gy.ntes:9092