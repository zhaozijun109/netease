execution-jar=${classpath}
class=com.netease.lofter.data.common.Hive2Kafka
conf.spark.source.query="select blogId from lofter_dm.ads_rec_high_revenue_blogs_di where dt='${azkaban.flow.1.days.ago}' "
params= --topic rec_bdms_high_payed_blog --servers lofter-kafka-recommend1.gy.ntes:9092,lofter-kafka-recommend2.gy.ntes:9092,lofter-kafka-recommend3.gy.ntes:9092
