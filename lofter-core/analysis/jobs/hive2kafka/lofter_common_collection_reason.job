execution-jar=${classpath}
class=com.netease.lofter.data.common.Hive2Kafka
conf.spark.source.query="select collectionId, recReason, priority from lofter_dm.ads_rec_collection_rec_reason_di where dt = '${azkaban.flow.1.days.ago}' "
params= --topic LOFTER.COMMON.COLLECTION.reason --servers lofter-kafka-dc1.gy.ntes:9092,lofter-kafka-dc2.gy.ntes:9092,lofter-kafka-dc3.gy.ntes:9092
