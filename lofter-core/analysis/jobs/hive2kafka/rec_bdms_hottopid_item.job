execution-jar=${classpath}
class=com.netease.lofter.data.common.Hive2Kafka
conf.spark.source.query="select tag, result from lofter_dm.ads_ecology_hot_search_result_dd where dt = '${azkaban.flow.1.days.ago}' "
params= --topic rec_bdms_hottopid_item --servers lofter-kafka-recommend1.gy.ntes:9092,lofter-kafka-recommend2.gy.ntes:9092,lofter-kafka-recommend3.gy.ntes:9092
