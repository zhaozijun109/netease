execution-jar=${classpath}
class=com.netease.lofter.data.common.Hive2Kafka
conf.spark.source.query="select userId,dt from lofter_dm.ads_user_black_low_quality_dd where dt='${azkaban.flow.1.days.ago}' "
params= --topic rec_bdms_low_blog  --servers lofter-kafka-recommend1.gy.ntes:9092,lofter-kafka-recommend2.gy.ntes:9092,lofter-kafka-recommend3.gy.ntes:9092