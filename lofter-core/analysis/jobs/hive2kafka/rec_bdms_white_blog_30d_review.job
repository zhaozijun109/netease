execution-jar=${classpath}
class=com.netease.lofter.data.common.Hive2Kafka
conf.spark.source.query="select blogid as blogId, published_post_cnt as publishedPostCnt,review_success_rate as rvPass30DRate from lofter.dws_recommend_blog_review_status_di where dt='${azkaban.flow.1.days.ago}'"
params= --topic rec_bdms_white_blog_30d_review --servers lofter-kafka-recommend1.gy.ntes:9092,lofter-kafka-recommend2.gy.ntes:9092,lofter-kafka-recommend3.gy.ntes:9092