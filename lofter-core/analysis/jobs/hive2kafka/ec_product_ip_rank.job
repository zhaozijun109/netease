execution-jar=${classpath}
class=com.netease.lofter.data.common.Hive2Kafka
conf.spark.source.query="select ipName, type, productId, cardActivityCode as activityCode, rank from lofter_dm.ads_ec_product_ip_rank_dd where dt = '${azkaban.flow.1.days.ago}'"
params= --topic LOFTER.MARKET.IP.PRODUCT.RANK --servers lofter-kafka-dc1.gy.ntes:9092,lofter-kafka-dc2.gy.ntes:9092,lofter-kafka-dc3.gy.ntes:9092
