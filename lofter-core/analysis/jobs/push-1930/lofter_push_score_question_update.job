type=sparksql
hive.query.01=insert overwrite table lofter_dm.ads_push_task_pool_di partition(dt = '${azkaban.flow.current.date}', executionId= 'score_question_update') \
select userId, \
       'LOFTER.PUSH.NEW.TASK' as push_topic, \
       to_json(struct(*)) as push_params, \
       'score_question_update' as policy, \
       1 as priority, \
       unix_timestamp()*1000L as create_time \
from ( \
    select 18 as messageType, userId, questionId \
    from lofter_dm.ads_push_score_question_update_di \
    where dt = '${azkaban.flow.current.date}' \
) t \

dependencies=ads_push_score_question_update_di