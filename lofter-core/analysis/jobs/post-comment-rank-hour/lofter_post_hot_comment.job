execution-jar=${classpath}
class=com.netease.lofter.data.common.Hive2ES
conf.spark.source.query="select postId, createTime, updateTime, hotCommentIds from lofter_dm.ads_post_comment_rank_di where dt = '${azkaban.flow.current.date}' and hour = ${azkaban.flow.start.hour}"
params= --id postId --dest lofter_post_hot_comment --update --url lofter-online-es1.gy.ntes:7000,lofter-online-es2.gy.ntes:7000,lofter-online-es3.gy.ntes:7000,lofter-online-es4.gy.ntes:7000 --username lofter_online --password Yi3DLCppSI --parallel 2
dependencies=ads_post_comment_rank_di
